#!/bin/sh

# Validate commit author matches expected identity
EXPECTED_NAME="wbern"
EXPECTED_EMAIL="wbern@users.noreply.github.com"

# Check for env vars that override git config (Gas Town sets these for agents)
BLOCKED=""
if [ -n "$GIT_AUTHOR_NAME" ] && [ "$GIT_AUTHOR_NAME" != "$EXPECTED_NAME" ]; then
  BLOCKED="${BLOCKED}  GIT_AUTHOR_NAME=$GIT_AUTHOR_NAME\n"
fi
if [ -n "$GIT_AUTHOR_EMAIL" ] && [ "$GIT_AUTHOR_EMAIL" != "$EXPECTED_EMAIL" ]; then
  BLOCKED="${BLOCKED}  GIT_AUTHOR_EMAIL=$GIT_AUTHOR_EMAIL\n"
fi
if [ -n "$GIT_COMMITTER_NAME" ] && [ "$GIT_COMMITTER_NAME" != "$EXPECTED_NAME" ]; then
  BLOCKED="${BLOCKED}  GIT_COMMITTER_NAME=$GIT_COMMITTER_NAME\n"
fi
if [ -n "$GIT_COMMITTER_EMAIL" ] && [ "$GIT_COMMITTER_EMAIL" != "$EXPECTED_EMAIL" ]; then
  BLOCKED="${BLOCKED}  GIT_COMMITTER_EMAIL=$GIT_COMMITTER_EMAIL\n"
fi

if [ -n "$BLOCKED" ]; then
  echo "Environment variables are overriding git author identity"
  echo "   Expected: $EXPECTED_NAME <$EXPECTED_EMAIL>"
  echo ""
  printf "   Offending variables:\n$BLOCKED"
  echo ""
  echo "Fix by unsetting them before committing:"
  echo "   unset GIT_AUTHOR_NAME GIT_AUTHOR_EMAIL GIT_COMMITTER_NAME GIT_COMMITTER_EMAIL"
  exit 1
fi

# Also validate git config itself
AUTHOR_NAME=$(git config user.name)
AUTHOR_EMAIL=$(git config user.email)

if [ "$AUTHOR_NAME" != "$EXPECTED_NAME" ] || [ "$AUTHOR_EMAIL" != "$EXPECTED_EMAIL" ]; then
  echo "Invalid git author configuration"
  echo "   Expected: $EXPECTED_NAME <$EXPECTED_EMAIL>"
  echo "   Got:      $AUTHOR_NAME <$AUTHOR_EMAIL>"
  echo ""
  echo "Fix with:"
  echo "   git config user.name \"$EXPECTED_NAME\""
  echo "   git config user.email \"$EXPECTED_EMAIL\""
  exit 1
fi

# Validate lockfile is up to date if package.json changed
if git diff --cached --name-only | grep -q "package.json"; then
  echo "package.json changed, validating lockfile..."
  pnpm install --frozen-lockfile || {
    echo "pnpm-lock.yaml is out of sync with package.json"
    echo "Run 'pnpm install' to update the lockfile and commit both files"
    exit 1
  }
fi

START_TIME=$SECONDS

# Run lint-staged (biome, tsc, secretlint on staged files)
pnpm exec lint-staged

# Check for unused code/dependencies
pnpm knip --no-config-hints

# Build
pnpm build

# Run tests with coverage (fails if below thresholds)
pnpm test:coverage

echo "Pre-commit completed in $((SECONDS - START_TIME))s"
